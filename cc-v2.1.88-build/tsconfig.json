{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": false,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "src/*": ["./src/*"],
      "bun:bundle": ["./shims/bun-bundle.ts"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*", "shims/**/*"]
}
